generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id                  String               @id @default(cuid())
  name                String               @unique
  slug                String               @unique
  category            String
  starRating          Int                  @default(3)
  address             String?
  city                String               @default("Kodaikanal")
  latitude            Float?
  longitude           Float?
  website             String?
  phone               String?
  isTarget            Boolean              @default(false)
  role                String               @default("competitor")
  luxuryTier          String?
  facilityScore       String?
  imageUrl            String?
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  competitorSnapshots CompetitorSnapshot[]
  dailyRates          DailyRate[]
  facilities          Facility[]
  otaBarAudits        OtaBarAudit[]
  rateHistory         RateHistory[]
  recommendations     Recommendation[]
  rooms               Room[]

  @@index([slug])
  @@index([isTarget])
}

model Room {
  id           String      @id @default(cuid())
  hotelId      String
  name         String
  type         String
  maxOccupancy Int         @default(2)
  bedType      String?
  hasLakeView  Boolean     @default(false)
  hasBalcony   Boolean     @default(false)
  sqft         Int?
  amenities    String[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  dailyRates   DailyRate[]
  hotel        Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, name])
  @@index([hotelId])
}

model DailyRate {
  id                 String   @id @default(cuid())
  hotelId            String
  roomId             String?
  date               DateTime @db.Date
  mapRate            Float?
  cpRate             Float?
  epRate             Float?
  rackRate           Float?
  taxPercent         Float?   @default(18)
  taxInclusive       Boolean  @default(false)
  totalWithTax       Float?
  singleOccRate      Float?
  doubleOccRate      Float?
  extraAdultRate     Float?
  extraChildRate     Float?
  source             String
  sourceUrl          String?
  isAvailable        Boolean  @default(true)
  roomsLeft          Int?
  breakfastIncluded  Boolean  @default(false)
  dinnerIncluded     Boolean  @default(false)
  lunchIncluded      Boolean  @default(false)
  mealDetails        String?
  cancellationPolicy String?
  freeCancellation   Boolean  @default(false)
  hasDiscount        Boolean  @default(false)
  discountPercent    Float?
  offerDescription   String?
  scrapedAt          DateTime @default(now())
  isValid            Boolean  @default(true)
  confidence         Float    @default(1.0)
  hotel              Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room               Room?    @relation(fields: [roomId], references: [id])

  @@index([hotelId, date])
  @@index([date])
  @@index([source])
  @@index([hotelId, date, source])
}

model Facility {
  id                 String   @id @default(cuid())
  hotelId            String
  normalizedKey      String
  name               String
  category           String
  available          Boolean  @default(true)
  quality            Int?     @default(3)
  level              String   @default("Standard")
  luxuryScore        Float?
  verificationSource String   @default("ota-verified")
  confidence         Float    @default(0.9)
  lastVerified       DateTime @default(now())
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  hotel              Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, normalizedKey])
  @@index([hotelId])
  @@index([normalizedKey])
}

model Recommendation {
  id                 String    @id @default(cuid())
  hotelId            String
  date               DateTime  @db.Date
  recommendedMapRate Float
  recommendedCpRate  Float?
  recommendedEpRate  Float?
  minRate            Float
  maxRate            Float
  optimalRate        Float
  strategy           String
  confidenceScore    Float
  reasoning          String
  avgCompetitorRate  Float?
  marketPosition     String?
  aiModel            String    @default("MiMo-7B-RL")
  aiPromptVersion    String?
  rawAiResponse      String?
  seasonType         String?
  demandLevel        String?
  weekendPremium     Float?    @default(0)
  createdAt          DateTime  @default(now())
  appliedAt          DateTime?
  isApplied          Boolean   @default(false)
  hotel              Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, date])
  @@index([date])
}

model RateHistory {
  id           String   @id @default(cuid())
  hotelId      String
  date         DateTime @db.Date
  mapRate      Float?
  cpRate       Float?
  epRate       Float?
  source       String
  deltaPercent Float?
  movingAvg7   Float?
  movingAvg30  Float?
  volatility   Float?
  createdAt    DateTime @default(now())
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, date, source])
  @@index([hotelId, date])
  @@index([date])
}

model CompetitorSnapshot {
  id               String   @id @default(cuid())
  hotelId          String
  date             DateTime @db.Date
  // TRUE VERIFIED BAR — lowest confirmed MAP rate across all OTAs
  bestMapRate      Float?
  bestCpRate       Float?
  bestEpRate       Float?
  bestSource       String?  // OTA that had the lowest verified MAP BAR
  worstMapRate     Float?
  avgMapRate       Float?
  availability     String?
  activeOffers     String?
  // Enterprise BAR metadata
  otaCount         Int      @default(0)  // Number of OTAs that returned MAP rates
  otasChecked      Int      @default(0)  // Total OTAs attempted
  otaBreakdown     String?  // JSON: {source: rate} for all OTAs that returned MAP rates
  verifiedAt       DateTime? // Timestamp of last cross-verification
  confidenceScore  Float    @default(0.5)
  confidenceLabel  String   @default("LOW") // HIGH | MEDIUM | LOW
  isStale          Boolean  @default(false)
  staleReason      String?
  anomalyFlags     String?  // JSON: list of anomaly descriptions
  roomCategory     String?  // Primary room tier used for this BAR
  taxNormalized    Boolean  @default(true) // All rates stored tax-inclusive
  createdAt        DateTime @default(now())
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, date])
  @@index([hotelId, date])
  @@index([date])
  @@index([confidenceLabel])
}

model ScrapeLog {
  id           String   @id @default(cuid())
  source       String
  hotelName    String?
  status       String
  duration     Int?
  ratesFound   Int      @default(0)
  errorMessage String?
  errorStack   String?
  retryCount   Int      @default(0)
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([source, createdAt])
  @@index([status])
}

model AiInsight {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  type       String
  title      String
  summary    String
  details    String?
  severity   String   @default("info")
  actionable Boolean  @default(true)
  confidence Float    @default(0.8)
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([type])
}

// AI reasoning audit trail — stores every MiMo prompt/response for auditability
model AiReasoningHistory {
  id               String   @id @default(cuid())
  model            String
  promptSnapshot   String   @db.Text
  rawResponse      String   @db.Text
  validationStatus String   @default("pending")
  validationErrors String?
  tokenUsage       Int?
  durationMs       Int?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([validationStatus])
}

// OTA BAR audit — per-OTA MAP rate log for every scrape cycle
// Enables true historical OTA winner tracking and rate spread analysis
model OtaBarAudit {
  id           String   @id @default(cuid())
  hotelId      String
  date         DateTime @db.Date
  scrapeWindow String   // '6am' | '12pm' | '6pm'
  source       String
  mapRate      Float?
  cpRate       Float?
  epRate       Float?
  roomType     String?
  mealPlan     String?  // MAP | CP | EP | UNKNOWN
  taxInclusive Boolean  @default(false)
  isWinner     Boolean  @default(false) // true if this OTA had the lowest MAP that cycle
  confidence   Float    @default(0.5)
  scrapedAt    DateTime @default(now())
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, date])
  @@index([date, source])
  @@index([isWinner, date])
}

// AI confidence tracking — monitors score drift over time
model AiConfidenceLog {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  confidenceScore    Float
  strategy           String
  seasonType         String?
  competitorDataHash String?
  createdAt          DateTime @default(now())

  @@index([date])
  @@index([createdAt])
}
